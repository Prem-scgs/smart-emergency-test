# Smart Emergency API environment checklist
#
# ไฟล์นี้เป็นตัวอย่างสำหรับ API host/container เท่านั้น ไม่ใช่ไฟล์ runtime
# ให้เก็บค่าใช้งานจริงไว้ใน services/emergency-api/.env หรือ secret manager
# และห้าม commit token, เบอร์โทรจริง หรือ DATABASE_URL ของระบบจริง

# Required: API ต้องเปิดที่พอร์ตนี้ เพราะ health check, Vercel rewrite และ tunnel ใช้อ้างอิง
PORT=4000

# Required for the machine/container that hosts the API. เปลี่ยนเป็นข้อมูลจริงใน .env
DATABASE_URL=postgres://<db-user>:<db-password>@<db-host>:5432/<db-name>

# Required: allowlist ของ frontend ที่เรียก API ได้ คั่นหลาย origin ด้วย comma
# Cloud-first test frontend ปัจจุบันอยู่บน Vercel
CORS_ORIGINS=https://smart-emergency-test.vercel.app

# Optional: ช่องทางแชร์ตำแหน่ง ใช้เมื่อยังไม่มีค่า override ใน System Settings ของ DB
# LINE_OA_ID=@your-line-oa
# SMS_CENTER_PHONE=<international-phone-number>
# WHATSAPP_CENTER_PHONE=<international-phone-number>

# Local fallback (ไม่ใช้บน Vercel):
# DATABASE_URL=postgres://emergency:emergency_dev@localhost:5432/smart_emergency
# CORS_ORIGINS=https://smart-emergency-test.vercel.app,http://localhost:3000,http://127.0.0.1:3000

# Docker local fallback: database host ต้องเป็นชื่อ service "db"
# DATABASE_URL=postgres://emergency:emergency_dev@db:5432/smart_emergency
# CORS_ORIGINS=https://smart-emergency-test.vercel.app,http://localhost:3000,http://127.0.0.1:3000,http://web:3000
