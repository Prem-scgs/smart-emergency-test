# syntax=docker/dockerfile:1.7
FROM node:22-alpine AS app

WORKDIR /app

ENV PNPM_HOME=/pnpm
ENV PATH=$PNPM_HOME:$PATH
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0

ARG EMERGENCY_API_INTERNAL_URL=http://api:4000
ENV EMERGENCY_API_INTERNAL_URL=$EMERGENCY_API_INTERNAL_URL

RUN corepack enable
RUN pnpm config set store-dir /pnpm/store

COPY package.json pnpm-lock.yaml pnpm-workspace.yaml ./
COPY services/emergency-api/package.json ./services/emergency-api/package.json
RUN --mount=type=cache,id=pnpm-store,target=/pnpm/store pnpm install --frozen-lockfile --prod=false

COPY . .
RUN pnpm build

EXPOSE 3000

CMD ["pnpm", "start"]
