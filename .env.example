# Smart Emergency frontend environment checklist
#
# ไฟล์นี้เป็น "ตัวอย่างและรายการค่าที่ต้องตั้ง" เท่านั้น ไม่ถูกโหลดเป็น runtime
# ห้าม copy secret, Cloudflare token หรือข้อมูลจริงลง Git

# Cloud-first: ตั้งใน Vercel Environment Variables สำหรับ frontend test
# REST/polling จะเรียกผ่าน Next rewrite ที่ /emergency-api
# SSE/EventSource ต้องใช้ URL API แบบ absolute เพราะเป็น connection ระยะยาว
NEXT_PUBLIC_EMERGENCY_API_EXTERNAL_URL=https://emer-api.scgs-ai.com
NEXT_PUBLIC_EMERGENCY_EVENTS_EXTERNAL_URL=https://emer-api.scgs-ai.com

# Local fallback: ใช้เฉพาะเมื่อรัน Next.js และ Fastify บนเครื่องเดียวกัน
# ห้ามตั้งค่านี้บน Vercel เป็น localhost, 127.0.0.1 หรือ http://api:4000
# EMERGENCY_API_INTERNAL_URL=http://127.0.0.1:4000

# Docker local fallback: docker-compose.local.yml ตั้งค่า internal URL ให้ web อยู่แล้ว
# EMERGENCY_API_INTERNAL_URL=http://api:4000
