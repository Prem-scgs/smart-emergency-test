# emergency-api local dev
# ค่าในไฟล์นี้ใช้เป็นตัวอย่างเท่านั้น ห้าม commit secret หรือ tunnel token จริง
PORT=4000
DATABASE_URL=postgres://emergency:emergency_dev@localhost:5432/smart_emergency
CORS_ORIGIN=http://localhost:3000

# Browser-side API targets for deployed frontend.
# Vercel test ควรชี้ API domain/Cloudflare tunnel ที่ออนไลน์อยู่
# REST/polling จะผ่าน /emergency-api rewrite ส่วน SSE/EventSource ใช้ absolute URL
# Current team test domain example:
# NEXT_PUBLIC_EMERGENCY_API_EXTERNAL_URL=https://emer-api.scgs-ai.com
# NEXT_PUBLIC_EMERGENCY_EVENTS_EXTERNAL_URL=https://emer-api.scgs-ai.com
# Legacy aliases still supported by shared/config:
# NEXT_PUBLIC_EMERGENCY_API_URL=https://your-api-domain.example.com
# NEXT_PUBLIC_EMERGENCY_SSE_URL=https://your-api-domain.example.com

# Next.js server-side rewrite target.
# Local dev uses localhost; Docker local stack uses http://api:4000 via docker-compose.local.yml.
EMERGENCY_API_INTERNAL_URL=http://127.0.0.1:4000
