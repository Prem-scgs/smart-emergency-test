# emergency-api local dev
PORT=4000
DATABASE_URL=postgres://emergency:emergency_dev@localhost:5432/smart_emergency
CORS_ORIGIN=http://localhost:3000

# Browser-side API targets for deployed frontend.
# Use NEXT_PUBLIC_EMERGENCY_API_URL for normal fetch calls.
# Use NEXT_PUBLIC_EMERGENCY_SSE_URL for EventSource/SSE so Vercel does not proxy long-lived streams.
# Example for Vercel + Cloudflare Tunnel:
# NEXT_PUBLIC_EMERGENCY_API_URL=https://your-api-tunnel.trycloudflare.com
# NEXT_PUBLIC_EMERGENCY_SSE_URL=https://your-api-tunnel.trycloudflare.com

# Next.js server-side rewrite target.
# Local dev uses localhost; Docker local stack uses http://api:4000 via docker-compose.local.yml.
EMERGENCY_API_INTERNAL_URL=http://127.0.0.1:4000
